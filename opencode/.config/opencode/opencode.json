{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-antigravity-auth@latest"],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git push *": "ask",
      "git reset *": "ask",
      "rm -rf /": "deny",
      "sudo *": "deny",
      "docker *": "ask",
      "kubectl *": "ask",
      "terraform *": "ask",
      "gcloud *": "ask",
      "aws *": "ask",
      "helm *": "ask"
    },
    "edit": "ask",
    "write": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "task": "ask"
  }
}
